# Copy this file to .env and fill in real values before running the project.
# .env is gitignored — never commit secrets.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/travel_planner

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# ── LLM (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CHEAP_MODEL=claude-haiku-4-5-20251001
STRONG_MODEL=claude-sonnet-4-6

# ── Embeddings ────────────────────────────────────────────────────────────────
# e.g. voyage-3 via Voyage AI, or text-embedding-3-small via OpenAI
EMBEDDING_MODEL=voyage-3
EMBEDDING_API_KEY=your-embedding-api-key

# ── Live Conditions APIs ──────────────────────────────────────────────────────
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1
AMADEUS_API_KEY=your-amadeus-key
AMADEUS_API_SECRET=your-amadeus-secret

# ── Webhook Delivery ──────────────────────────────────────────────────────────
WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3

# ── RAG Chunking ──────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RAG_TOP_K=5

# ── LangSmith Tracing (optional) ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-key
LANGCHAIN_PROJECT=smart-travel-planner
