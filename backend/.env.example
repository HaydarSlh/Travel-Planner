# Copy this file to .env and fill in real values. .env is gitignored.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/travel_planner

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# ── LLM (Gemini) ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
CHEAP_MODEL=gemini-1.5-flash
STRONG_MODEL=gemini-2.5-flash

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIM=768

# ── Live Conditions APIs ──────────────────────────────────────────────────────
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# ── Webhook Delivery ──────────────────────────────────────────────────────────
WEBHOOK_URL=
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3

# ── RAG ───────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RAG_TOP_K=5

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── LangSmith Tracing (optional) ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=smart-travel-planner
